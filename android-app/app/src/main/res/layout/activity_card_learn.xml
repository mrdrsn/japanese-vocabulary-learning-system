<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/card_learn_background"
    android:clipChildren="false"
    android:clipToPadding="false">

    <ImageView
        android:id="@+id/lexicalTopRectangle"
        android:layout_width="0dp"
        android:layout_height="165dp"
        android:contentDescription="@null"
        android:scaleType="fitXY"
        android:src="@drawable/card_learn_top"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="110dp"
        android:layout_height="0dp"
        android:contentDescription="Назад"
        android:scaleType="fitXY"
        android:src="@drawable/back_button"
        android:layout_marginStart="16dp"
        android:layout_marginTop="25dp"
        app:layout_constraintDimensionRatio="120:55"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvScenarioName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/sfprodisplay_medium"
        android:text="Поход в convenience store"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:layout_marginTop="72dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvCardQuantity"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/sfprodisplay_regular"
        android:text="0/9 карточек изучено"
        android:textAlignment="center"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginTop="6dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvScenarioName" />

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="355dp"
        android:layout_height="10dp"
        android:indeterminate="false"
        android:progressDrawable="@drawable/bg_card_progress"
        android:elevation="4dp"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCardQuantity" />

    <!-- padding + clipChildren=false дают тени место для рендера -->
    <FrameLayout
        android:id="@+id/cardContainer"
        android:layout_width="380dp"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="110dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lexicalTopRectangle">

        <!-- лицевая сторона -->
        <androidx.cardview.widget.CardView
            android:id="@+id/frontCard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:cardBackgroundColor="#E5E5E5"
            app:cardCornerRadius="37dp"
            app:cardElevation="6dp"
            app:cardUseCompatPadding="false">

            <TextView
                android:id="@+id/tvRomaji"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fontFamily="@font/sfprodisplay_regular"
                android:gravity="center"
                android:padding="24dp"
                android:text="Kekkō desu"
                android:textColor="#000000"
                android:textSize="50sp" />

        </androidx.cardview.widget.CardView>

        <!-- задняя сторона (изначально скрыта) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/backCard"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:visibility="gone"
            app:cardBackgroundColor="#E5E5E5"
            app:cardCornerRadius="37dp"
            app:cardElevation="6dp"
            app:cardUseCompatPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:padding="32dp">

                <TextView
                    android:id="@+id/tvTranslation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/sfprodisplay_regular"
                    android:gravity="center"
                    android:text="Нет, спасибо"
                    android:textColor="#000000"
                    android:textSize="50sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvRoleLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_info_tag_blue"
                        android:fontFamily="@font/sfprodisplay_regular"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="Роль"
                        android:textColor="#2D3F8F"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvRoleValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="@font/sfprodisplay_regular"
                        android:text="Гость"
                        android:textColor="#000000"
                        android:textSize="21sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="11dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvIntentLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="20dp"
                        android:background="@drawable/bg_info_tag_blue"
                        android:fontFamily="@font/sfprodisplay_regular"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:text="Намерение"
                        android:textColor="#2D3F8F"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvIntentValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:fontFamily="@font/sfprodisplay_regular"
                        android:text="Мягкий отказ"
                        android:textColor="#000000"
                        android:textSize="21sp" />

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>

    <ImageView
        android:id="@+id/btnCross"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Не знаю"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_card_cross"
        android:layout_marginStart="25dp"
        android:layout_marginBottom="15dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/btnCheck"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="Знаю"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_card_check"
        android:layout_marginEnd="25dp"
        android:layout_marginBottom="15dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>