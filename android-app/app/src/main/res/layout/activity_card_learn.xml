<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/card_learn_background"
    tools:context=".CardLearnActivity">

    <ImageView
    android:id="@+id/lexicalTopRectangle"
    android:layout_width="414dp"
    android:layout_height="165dp"
    android:contentDescription="Вернуться на предыдущий экран"
    android:scaleType="fitXY"
    android:src="@drawable/card_learn_top"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    />

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="110dp"
        android:layout_height="0dp"
        android:contentDescription="Вернуться на предыдущий экран"
        android:scaleType="fitXY"
        android:src="@drawable/back_button"
        app:layout_constraintDimensionRatio="120:55"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="25dp" />

    <TextView
        android:id="@+id/tvScenarioName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="75dp"
        android:textAlignment="center"
        android:fontFamily="@font/sfprodisplay_medium"
        android:textSize="20sp"
        android:text="Поход в convenience store"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:textColor="#FFFFFF"/>
    <TextView
        android:id="@+id/tvCardQuantity"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:textAlignment="center"
        android:fontFamily="@font/sfprodisplay_regular"
        android:textSize="20sp"
        android:text="1/25 карточек"
        app:layout_constraintStart_toStartOf="@+id/tvScenarioName"
        app:layout_constraintEnd_toEndOf="@+id/tvScenarioName"
        app:layout_constraintTop_toTopOf="@+id/tvScenarioName"
        android:textColor="#FFFFFF"/>

    <ImageView
    android:id="@+id/btnCross"
    android:layout_width="wrap_content"
    android:layout_height="0dp"
    android:contentDescription="Вернуться на предыдущий экран"
    android:scaleType="fitXY"
    android:src="@drawable/ic_card_cross"
    android:layout_marginBottom="25dp"
    android:layout_marginStart="25dp"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintBottom_toBottomOf="parent" />

    <ImageView
        android:id="@+id/btnCheck"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:contentDescription="Вернуться на предыдущий экран"
        android:scaleType="fitXY"
        android:src="@drawable/ic_card_check"
        android:layout_marginBottom="25dp"
        android:layout_marginEnd="25dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>