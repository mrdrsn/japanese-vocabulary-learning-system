<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_exercise_type_d">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@+id/btnSubmitAnswer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <include layout="@layout/view_exercise_header" />

            <TextView
                android:id="@+id/tvInstruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="28dp"
                android:fontFamily="@font/sfprodisplay_regular"
                android:includeFontPadding="false"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:textColor="#FFFFFF"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/btnSpeaker"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:background="@drawable/bg_speaker_circle"
                android:contentDescription="Прослушать фразу"
                android:padding="28dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_speakerv2" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/sfprodisplay_medium"
                android:text="Что было сказано:"
                android:textColor="#1A1A1A"
                android:textSize="16sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSaid1"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_exercise_option"
                android:fontFamily="@font/sfprodisplay_regular"
                android:includeFontPadding="false"
                android:stateListAnimator="@null"
                android:textColor="#1A1A1A"
                android:textSize="16sp"
                app:backgroundTint="@null" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSaid2"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_exercise_option"
                android:fontFamily="@font/sfprodisplay_regular"
                android:includeFontPadding="false"
                android:stateListAnimator="@null"
                android:textColor="#1A1A1A"
                android:textSize="16sp"
                app:backgroundTint="@null" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="12dp"
                android:fontFamily="@font/sfprodisplay_medium"
                android:text="Как Вы ответите:"
                android:textColor="#1A1A1A"
                android:textSize="16sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnResp1"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_exercise_option"
                android:fontFamily="@font/sfprodisplay_regular"
                android:includeFontPadding="false"
                android:stateListAnimator="@null"
                android:textColor="#1A1A1A"
                android:textSize="16sp"
                app:backgroundTint="@null" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnResp2"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_exercise_option"
                android:fontFamily="@font/sfprodisplay_regular"
                android:includeFontPadding="false"
                android:stateListAnimator="@null"
                android:textColor="#1A1A1A"
                android:textSize="16sp"
                app:backgroundTint="@null" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnSubmitAnswer"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_exercise_submit"
        android:fontFamily="@font/sfprodisplay_medium"
        android:includeFontPadding="false"
        android:stateListAnimator="@null"
        android:text="Ответить"
        android:textColor="#1A1A1A"
        android:textSize="17sp"
        android:visibility="gone"
        app:backgroundTint="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>